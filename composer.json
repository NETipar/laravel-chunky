{
    "name": "netipar/laravel-chunky",
    "description": "Chunk-based file upload package for Laravel with event-driven architecture",
    "keywords": ["laravel", "chunk", "upload", "file"],
    "license": "MIT",
    "authors": [
        {
            "name": "NETipar",
            "email": "dev@netipar.hu"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/routing": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/filesystem": "^11.0|^12.0",
        "illuminate/bus": "^11.0|^12.0",
        "illuminate/queue": "^11.0|^12.0"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "NETipar\\Chunky\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NETipar\\Chunky\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "NETipar\\Chunky\\ChunkyServiceProvider"
            ],
            "aliases": {
                "Chunky": "NETipar\\Chunky\\Facades\\Chunky"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "suggest": {
        "livewire/livewire": "Required for the Livewire chunk upload component (^3.0)"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
