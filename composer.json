{
    "name": "netipar/laravel-chunky",
    "description": "Chunk-based file upload package for Laravel with event-driven architecture, resume support, batch upload, and framework-agnostic frontend clients for Vue 3, React, Alpine.js, and Livewire.",
    "keywords": [
        "laravel",
        "chunk",
        "upload",
        "file",
        "file-upload",
        "resumable",
        "large-files",
        "batch-upload",
        "s3",
        "echo",
        "broadcasting",
        "vue",
        "react",
        "alpine",
        "livewire"
    ],
    "license": "MIT",
    "homepage": "https://github.com/NETipar/laravel-chunky",
    "support": {
        "issues": "https://github.com/NETipar/laravel-chunky/issues",
        "source": "https://github.com/NETipar/laravel-chunky",
        "docs": "https://github.com/NETipar/laravel-chunky#readme",
        "security": "https://github.com/NETipar/laravel-chunky/security/policy"
    },
    "authors": [
        {
            "name": "NETipar",
            "email": "dev@netipar.hu",
            "homepage": "https://netipar.hu"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^11.0|^12.0|^13.0",
        "illuminate/bus": "^11.0|^12.0|^13.0",
        "illuminate/queue": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "mockery/mockery": "^1.6",
        "larastan/larastan": "^2.9|^3.0"
    },
    "autoload": {
        "psr-4": {
            "NETipar\\Chunky\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NETipar\\Chunky\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "NETipar\\Chunky\\ChunkyServiceProvider"
            ],
            "aliases": {
                "Chunky": "NETipar\\Chunky\\Facades\\Chunky"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=2G",
        "ci": [
            "@format -- --test",
            "@analyse",
            "@test"
        ]
    },
    "suggest": {
        "livewire/livewire": "Required for the Livewire chunk upload component (^3.0)"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
