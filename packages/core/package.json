{
    "name": "@netipar/chunky-core",
    "version": "0.22.2",
    "description": "Framework-agnostic chunk upload engine for Laravel Chunky",
    "type": "module",
    "main": "dist/index.js",
    "types": "types/index.d.ts",
    "exports": {
        ".": {
            "types": "./types/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "default": "./dist/index.js"
        },
        "./tools": {
            "types": "./types/tools.d.ts",
            "import": "./dist/tools.js",
            "require": "./dist/tools.cjs",
            "default": "./dist/tools.js"
        }
    },
    "files": [
        "dist",
        "types",
        "src"
    ],
    "scripts": {
        "build": "tsc --noEmit -p tsconfig.json && node build.js && tsc -p tsconfig.build.json"
    },
    "keywords": [
        "chunky",
        "upload",
        "chunk",
        "file-upload",
        "laravel"
    ],
    "license": "MIT",
    "homepage": "https://github.com/NETipar/laravel-chunky",
    "repository": {
        "type": "git",
        "url": "https://github.com/NETipar/laravel-chunky.git",
        "directory": "packages/core"
    },
    "publishConfig": {
        "access": "public"
    },
    "sideEffects": false
}
