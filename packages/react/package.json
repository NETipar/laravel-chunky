{
    "name": "@netipar/chunky-react",
    "version": "0.17.1",
    "description": "React hook for Laravel Chunky chunk uploads",
    "type": "module",
    "main": "dist/index.js",
    "types": "types/index.d.ts",
    "exports": {
        ".": {
            "types": "./types/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist",
        "types",
        "src"
    ],
    "scripts": {
        "build": "node build.js && tsc --emitDeclarationOnly"
    },
    "keywords": [
        "chunky",
        "upload",
        "chunk",
        "file-upload",
        "laravel",
        "react",
        "hook"
    ],
    "license": "MIT",
    "homepage": "https://github.com/NETipar/laravel-chunky",
    "repository": {
        "type": "git",
        "url": "https://github.com/NETipar/laravel-chunky.git",
        "directory": "packages/react"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@netipar/chunky-core": "workspace:^"
    },
    "peerDependencies": {
        "react": "^19.2"
    },
    "devDependencies": {
        "typescript": "^6.0",
        "esbuild": "^0.28",
        "react": "^19.2",
        "@types/react": "^18.0 || ^19.0"
    }
}
