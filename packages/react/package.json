{
    "name": "@netipar/chunky-react",
    "version": "0.22.0",
    "description": "React hook for Laravel Chunky chunk uploads",
    "type": "module",
    "main": "dist/index.js",
    "types": "types/index.d.ts",
    "exports": {
        ".": {
            "types": "./types/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "types",
        "src"
    ],
    "scripts": {
        "build": "tsc --noEmit -p tsconfig.json && node build.js && tsc -p tsconfig.build.json"
    },
    "keywords": [
        "chunky",
        "upload",
        "chunk",
        "file-upload",
        "laravel",
        "react",
        "hook"
    ],
    "license": "MIT",
    "homepage": "https://github.com/NETipar/laravel-chunky",
    "repository": {
        "type": "git",
        "url": "https://github.com/NETipar/laravel-chunky.git",
        "directory": "packages/react"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@netipar/chunky-core": "workspace:^"
    },
    "peerDependencies": {
        "react": "^19.2"
    },
    "devDependencies": {
        "react": "^19.2",
        "@types/react": "^18.0 || ^19.0"
    },
    "sideEffects": false
}
