{
    "name": "@netipar/chunky-vue3",
    "version": "0.12.0",
    "description": "Vue 3 composable and components for Laravel Chunky chunk uploads",
    "type": "module",
    "main": "dist/index.js",
    "types": "types/index.d.ts",
    "exports": {
        ".": {
            "types": "./types/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist",
        "types",
        "src"
    ],
    "scripts": {
        "build": "node build.js && tsc --emitDeclarationOnly"
    },
    "keywords": ["chunky", "upload", "chunk", "file-upload", "laravel", "vue", "vue3", "composable"],
    "license": "MIT",
    "homepage": "https://github.com/NETipar/laravel-chunky",
    "repository": {
        "type": "git",
        "url": "https://github.com/NETipar/laravel-chunky.git",
        "directory": "packages/vue3"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@netipar/chunky-core": "workspace:^"
    },
    "peerDependencies": {
        "vue": "^3.4"
    },
    "peerDependenciesMeta": {
        "dropzone": {
            "optional": true
        }
    },
    "devDependencies": {
        "typescript": "^5.4",
        "esbuild": "^0.21",
        "vue": "^3.4"
    }
}
