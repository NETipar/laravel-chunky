{
    "name": "@netipar/chunky-vue3",
    "version": "0.19.0",
    "description": "Vue 3 composable and components for Laravel Chunky chunk uploads",
    "type": "module",
    "main": "dist/index.js",
    "types": "types/index.d.ts",
    "exports": {
        ".": {
            "types": "./types/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist",
        "types",
        "src"
    ],
    "scripts": {
        "build": "node build.js && tsc -p tsconfig.build.json"
    },
    "keywords": [
        "chunky",
        "upload",
        "chunk",
        "file-upload",
        "laravel",
        "vue",
        "vue3",
        "composable"
    ],
    "license": "MIT",
    "homepage": "https://github.com/NETipar/laravel-chunky",
    "repository": {
        "type": "git",
        "url": "https://github.com/NETipar/laravel-chunky.git",
        "directory": "packages/vue3"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@netipar/chunky-core": "workspace:^"
    },
    "peerDependencies": {
        "vue": "^3.5",
        "dropzone": "^5.9 || ^6.0.0-beta"
    },
    "peerDependenciesMeta": {
        "dropzone": {
            "optional": true
        }
    },
    "devDependencies": {
        "vue": "^3.5"
    }
}
